    },
    "dependencies": {
        "@fancyapps/fancybox": "3.5.7",
        "bootstrap": "4.6.0",
        "html5-device-mockups": "^3.2.1",
        "jquery": "3.6.0",
        "jquery.easing": "^1.4.1",
        "slick-carousel": "^1.8.1"
    },
    "devDependencies": {
